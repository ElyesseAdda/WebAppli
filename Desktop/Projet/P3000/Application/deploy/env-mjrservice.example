# =============================================================================
# Configuration .env pour MJRSERVICE
# =============================================================================
# Copiez ce fichier vers .env sur le serveur /var/www/mjrservice/Desktop/Projet/P3000/Application/
# Remplacez SECRET_KEY par la clé affichée par setup-new-client.sh (ou générez-en une)
# =============================================================================

# -----------------------------------------------------------------------------
# IDENTIFICATION
# -----------------------------------------------------------------------------
CLIENT_NAME=mjrservice
CLIENT_DOMAIN=mjrserviceapp.com

# -----------------------------------------------------------------------------
# DJANGO
# -----------------------------------------------------------------------------
DEBUG=False
SECRET_KEY=REMPLACER_PAR_CLE_SCRIPT_OU_GENERER
ALLOWED_HOSTS=mjrserviceapp.com,www.mjrserviceapp.com

# -----------------------------------------------------------------------------
# BASE DE DONNÉES
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://p3000user:Boumediene30@localhost:5432/p3000db_mjrservice

# -----------------------------------------------------------------------------
# AWS S3
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=AKIAXMY6JOBSJADL42QL
AWS_SECRET_ACCESS_KEY=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
AWS_STORAGE_BUCKET_NAME=mjrservices
AWS_S3_REGION_NAME=eu-north-1
AWS_S3_CUSTOM_DOMAIN=mjrservices.s3.eu-north-1.amazonaws.com

# -----------------------------------------------------------------------------
# SÉCURITÉ
# -----------------------------------------------------------------------------
CSRF_TRUSTED_ORIGINS=https://mjrserviceapp.com,https://www.mjrserviceapp.com
CORS_ALLOWED_ORIGINS=https://mjrserviceapp.com,https://www.mjrserviceapp.com
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True

# -----------------------------------------------------------------------------
# REDIS (DB 2 pour MJRSERVICE, DB 0=P3000, DB 1=Elekable)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=/var/log/mjrservice/django.log

# -----------------------------------------------------------------------------
# EMAIL (optionnel)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# -----------------------------------------------------------------------------
# ONLYOFFICE (partagé - même config que P3000/Elekable)
# -----------------------------------------------------------------------------
CLIENT_PUBLIC_DOMAIN=mjrserviceapp.com
ONLYOFFICE_SERVER_URL=https://office.elekable.fr
ONLYOFFICE_JWT_SECRET=Ayla220223@@
ONLYOFFICE_JWT_ENABLED=true
